# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql://anif:anif_dev@localhost:5432/anif
DATABASE_URL=postgresql://anif:anif_dev@localhost:5432/anif

# ── Cache / Queue ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Source of Truth ───────────────────────────────────────────────────────────
# Select backend: nautobot | netbox | infrahub
SOT_BACKEND=nautobot

NAUTOBOT_URL=http://localhost:8080
NAUTOBOT_TOKEN=your-nautobot-token-here

NETBOX_URL=http://localhost:8000
NETBOX_TOKEN=your-netbox-token-here

INFRAHUB_URL=http://localhost:8000
INFRAHUB_TOKEN=your-infrahub-token-here

# ── Observability ─────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090

# ── Frontend / Design ─────────────────────────────────────────────────────────
FIGMA_TOKEN=your-figma-token-here

# ── Platform ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development

# API key required by all platform endpoints (X-API-Key header).
# Placeholder auth until X.509 gateway wiring lands.
ANIF_API_KEY=dev-local-api-key

# ── Frontend (vite) ───────────────────────────────────────────────────────────
# Vite only reads env files from src/anif_ui/ — put these in
# src/anif_ui/.env.local for local dev. The dev server proxies /api → backend.
# VITE_ANIF_API_KEY=dev-local-api-key
# VITE_API_BASE_URL=/api
# VITE_API_PROXY_TARGET=http://localhost:8000

# ── MCP: Tavily (web search) ──────────────────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key-here

# ── MCP: Context7 (library docs) ─────────────────────────────────────────────
# Optional — higher rate limits with key; works without it
CONTEXT7_API_KEY=your-context7-api-key-here

# ── MCP: Memory (persistent memory file) ─────────────────────────────────────
# Optional — defaults to memory.jsonl in working directory
MEMORY_FILE_PATH=.claude/memory.jsonl

# ── ANIF Companion Repo ───────────────────────────────────────────────────────
ANIF_SPEC_REPO_PATH=/home/dan/Desktop/github/Autonomous-Networking-Infrastructure-Framework-ANIF
